# 실제 값을 채운 뒤 .env로 저장하고, 절대 커밋하지 마세요.

# --- jetson/ ---
YOLOV5_REPO_PATH=/home/jetson/yolov5
MODEL_WEIGHTS_PATH=/home/jetson/yolov5/runs/train/sandwich_please3/weights/best.pt
CAMERA_STREAM_URL=http://<라즈베리파이_IP>:8081  # 라즈베리파이가 motionEye로 송출하는 스트림
JETSON_SOCKET_HOST=0.0.0.0
JETSON_SOCKET_PORT=65432

# --- pi/ ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-google-cloud-service-account.json
JETSON_HOST=192.168.0.100
JETSON_PORT=65432
PI_AUDIO_DEVICE_INDEX=2
PI_ALSA_DEVICE=plughw:1,0
VOICE_ASSET_DIR=../assets/voice

# --- experiments/ (웨이크워드 관련 프로토타입에서만 사용) ---
PICOVOICE_ACCESS_KEY=your-picovoice-access-key
PORCUPINE_KEYWORD_PATH=/path/to/your-wakeword.ppn
